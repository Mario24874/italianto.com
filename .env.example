############################################################
# ITALIANTO PLATFORM — Variables de entorno
# Copia este archivo como .env.local para desarrollo
# cp .env.example .env.local
#
# IMPORTANTE: NUNCA subas .env.local a git.
# Para producción (EasyPanel), carga estas variables
# directamente en el panel de la aplicación.
############################################################

# ══════════════════════════════════════════════════════════
# 1. CLERK — Autenticación
#    https://dashboard.clerk.com
#
#    PASOS:
#    a) Crear cuenta en clerk.com
#    b) Crear una nueva Application → elegir nombre "Italianto"
#    c) En "API Keys" copiar las keys de abajo
#    d) En "Webhooks" → Add Endpoint:
#       URL: https://italianto.com/api/clerk/webhook
#       Eventos a suscribir: user.created, user.updated, user.deleted
#       Copiar el "Signing Secret" en CLERK_WEBHOOK_SECRET
#    e) En "Social Connections" activar Google y/o Apple si deseas OAuth
#    f) NOTA: Las mismas keys de Clerk se usan en las 3 apps
#       (italianto-master, ItaliantoApp, dialogue-studio)
# ══════════════════════════════════════════════════════════
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# URLs de redirección de Clerk (no cambiar salvo personalización)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/precios


# ══════════════════════════════════════════════════════════
# 2. SUPABASE — Base de datos unificada (UN SOLO PROYECTO)
#    https://supabase.com/dashboard
#
#    ⚠️  ESTRATEGIA: Un único proyecto Supabase para las 3 apps.
#    Así no necesitas plan Pro y evitas el límite de 2 proyectos.
#
#    PASOS:
#    a) Ir a supabase.com → New Project
#       Nombre: "italianto-unified"
#       Contraseña DB: genera una segura (guárdala)
#       Región: la más cercana a tus usuarios (us-east-1 para Venezuela)
#    b) Ir a Settings → API:
#       - "Project URL" → NEXT_PUBLIC_SUPABASE_URL
#       - "anon public" key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#       - "service_role secret" key → SUPABASE_SERVICE_ROLE_KEY
#    c) Ir a SQL Editor → New Query → pegar y ejecutar:
#       supabase/schema-unified.sql (de este repo)
#    d) Activar Row Level Security ya está configurado en el schema
#
#    ANTI-PAUSA (proyectos gratis se pausan a los 7 días):
#    Ver sección "CRON KEEP-ALIVE" al final de este archivo.
#    También disponible en: docs/anti-pausa.md
# ══════════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ══════════════════════════════════════════════════════════
# 3. STRIPE — Pagos y suscripciones
#    https://dashboard.stripe.com
#
#    PASOS:
#    a) Crear cuenta en stripe.com (o usar la existente de dialogue-studio)
#    b) Ir a Developers → API Keys:
#       - "Secret key" → STRIPE_SECRET_KEY
#       - Usar sk_test_... para pruebas, sk_live_... para producción
#    c) Crear 3 Products con sus Price IDs:
#
#       Producto 1: "Italianto Essenziale"
#         - Price mensual: $12 USD/month → STRIPE_PRICE_ESSENZIALE_MONTHLY
#         - Price anual:   $99 USD/year  → STRIPE_PRICE_ESSENZIALE_ANNUAL
#         - Product ID     → STRIPE_PRODUCT_ESSENZIALE
#
#       Producto 2: "Italianto Avanzato"
#         - Price mensual: $29 USD/month → STRIPE_PRICE_AVANZATO_MONTHLY
#         - Price anual:   $249 USD/year → STRIPE_PRICE_AVANZATO_ANNUAL
#         - Product ID     → STRIPE_PRODUCT_AVANZATO
#
#       Producto 3: "Italianto Maestro"
#         - Price mensual: $79 USD/month → STRIPE_PRICE_MAESTRO_MONTHLY
#         - Price anual:   $699 USD/year → STRIPE_PRICE_MAESTRO_ANNUAL
#         - Product ID     → STRIPE_PRODUCT_MAESTRO
#
#    d) Crear Webhook:
#       Developers → Webhooks → Add Endpoint
#       URL: https://italianto.com/api/stripe/webhook
#       Eventos: checkout.session.completed,
#                customer.subscription.created,
#                customer.subscription.updated,
#                customer.subscription.deleted
#       Copiar "Signing secret" → STRIPE_WEBHOOK_SECRET
#
#    ⚡ Para pruebas locales usar Stripe CLI:
#       stripe listen --forward-to localhost:3000/api/stripe/webhook
# ══════════════════════════════════════════════════════════
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

STRIPE_PRICE_ESSENZIALE_MONTHLY=price_...
STRIPE_PRICE_ESSENZIALE_ANNUAL=price_...
STRIPE_PRICE_AVANZATO_MONTHLY=price_...
STRIPE_PRICE_AVANZATO_ANNUAL=price_...
STRIPE_PRICE_MAESTRO_MONTHLY=price_...
STRIPE_PRICE_MAESTRO_ANNUAL=price_...

STRIPE_PRODUCT_ESSENZIALE=prod_...
STRIPE_PRODUCT_AVANZATO=prod_...
STRIPE_PRODUCT_MAESTRO=prod_...

# ══════════════════════════════════════════════════════════
# 4. APLICACIÓN — URLs y configuración general
#
#    Durante desarrollo: NEXT_PUBLIC_APP_URL=http://localhost:3000
#    En producción: NEXT_PUBLIC_APP_URL=https://italianto.com
# ══════════════════════════════════════════════════════════
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URLs de las apps hermanas (path-based bajo italianto.com)
NEXT_PUBLIC_APP_ITALIANTO_URL=https://italianto.com/app
NEXT_PUBLIC_APP_STUDIO_URL=https://italianto.com/studio

# URLs internas Docker para el proxy de Next.js rewrites
# En Easypanel los servicios se llaman por su nombre de contenedor
DIALOGHI_STUDIO_INTERNAL_URL=http://dialoghi-studio:3000
ITALIANTOAPP_INTERNAL_URL=http://italiantoapp:3000

# Email(s) con acceso al portal /admin (separados por coma)
# Debe coincidir exactamente con el email de tu cuenta Clerk
ADMIN_EMAILS=tu@email.com

# ══════════════════════════════════════════════════════════
# 5. CRON SECRETS — Seguridad de endpoints automáticos
#
#    Genera un string aleatorio largo para proteger los
#    endpoints de cron job. Puedes usar:
#      node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    O en bash: openssl rand -hex 32
# ══════════════════════════════════════════════════════════

# Para el reset mensual de quotas: POST /api/quota-reset
CRON_SECRET=genera-con-openssl-rand-hex-32-aqui

# Para el keep-alive de Supabase: GET /api/keep-alive
# Puede ser el mismo CRON_SECRET o uno diferente
KEEP_ALIVE_SECRET=genera-con-openssl-rand-hex-32-aqui

# ══════════════════════════════════════════════════════════
# 6. EMAILJS — Formulario de contacto (opcional)
#    https://www.emailjs.com
#
#    PASOS (plan gratuito: 200 emails/mes):
#    a) Crear cuenta en emailjs.com
#    b) Email Services → Add New Service → Gmail o SMTP
#       Copiar Service ID → NEXT_PUBLIC_EMAILJS_SERVICE_ID
#    c) Email Templates → Create New Template
#       Variables útiles: {{from_name}}, {{from_email}}, {{message}}
#       Copiar Template ID → NEXT_PUBLIC_EMAILJS_TEMPLATE_ID
#    d) Account → General → Public Key
#       Copiar → NEXT_PUBLIC_EMAILJS_PUBLIC_KEY
# ══════════════════════════════════════════════════════════
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx

############################################################
# ══════════════════════════════════════════════════════════
# SOLUCIÓN ANTI-PAUSA DE SUPABASE (GRATIS)
# ══════════════════════════════════════════════════════════
#
# Supabase pausa proyectos gratis si no hay actividad en 7 días.
# Solución: configurar un cron job gratuito en cron-job.org
#
# CONFIGURACIÓN EN CRON-JOB.ORG:
# ────────────────────────────────
# 1. Ir a https://cron-job.org → Create free account
# 2. Dashboard → CREATE CRONJOB con estos datos:
#
#    Título:    "Italianto Supabase Keep-Alive"
#    URL:       https://italianto.com/api/keep-alive
#    Método:    GET
#    Headers:   Authorization: Bearer <valor de KEEP_ALIVE_SECRET>
#    Schedule:  Every 3 days (o "0 8 */3 * *" en cron syntax)
#    Enabled:   ✓
#
# 3. Crear un segundo cron job para el reset mensual de quotas:
#
#    Título:    "Italianto Quota Reset"
#    URL:       https://italianto.com/api/quota-reset
#    Método:    POST
#    Headers:   Authorization: Bearer <valor de CRON_SECRET>
#    Schedule:  First day of month at 00:05 AM ("5 0 1 * *")
#
# ALTERNATIVA GRATUITA — GitHub Actions (si el repo es público/privado):
# Crear .github/workflows/keep-alive.yml con el contenido del
# archivo docs/github-keep-alive.yml de este repo.
#
# ¿Por qué no usar Supabase Pro para resolver el pausing?
# Pro cuesta $25/mes por organización. Con un cron job gratuito
# en cron-job.org resolvemos el mismo problema sin costo.
# Cuando el proyecto genere ingresos, migrar a Pro es directo.
############################################################
